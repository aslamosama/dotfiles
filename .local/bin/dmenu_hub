#!/usr/bin/env sh

dmenu_command="dmenu -i"

menu=$(
  cat <<EOF
¾░Ć╗  Apps            | dmenu_run -i -p "dmenu_run:"
’Ćé  Web Search      | dmenu_web
’üä  Edit Configs    | st -e confedit
Ņ½å  Light/Dark      | themeflip
¾░ī╣  Handler         | dmenuhandler
ŅŁī  Screenshot      | maimpick
Ņ«¦  Record          | dmenurecord
¾░īī  Keybinds        | keybinds
¾░ē”  Bar colors      | bar_colors_toggle
¾░ŗŖ  Mount           | mounter
¾▒üī  Unmount         | unmounter
¾░ää  Camera          | bash -c 'mpv --untimed --no-cache --no-config --no-osc --no-input-default-bindings --profile=low-latency --input-conf=/dev/null --title=webcam $(ls /dev/video[0,2,4,6,8] | tail -n 1)'
’üŚ  Kill            | processkill
Ņēģ  NerdFont Icons  | dmenunerdsymbols
EOF
)

options=$(echo "$menu" | cut -d '|' -f1 | sed 's/[[:space:]]*$//')
selected_option=$(echo "$options" | eval "$dmenu_command")
if [ -n "$selected_option" ]; then
  action=$(echo "$menu" | awk -F'|' -v option="$selected_option" '$1 ~ option {print $2}')
  [ -n "$action" ] && eval "$action"
fi
